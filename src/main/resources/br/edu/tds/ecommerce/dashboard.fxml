<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane fx:id="painelPrincipal" prefHeight="900.0" prefWidth="1600.0" stylesheets="@dashboard.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.edu.tds.ecommerce.DashboardController">

    <!-- SIDEBAR -->

    <left>

        <AnchorPane prefWidth="280.0" styleClass="sidebar" stylesheets="@dashboard.css">

            <children>

                <!-- BOTÃO LOGOUT -->

                <Button layoutX="40.0" layoutY="780.0" onAction="#logout" prefWidth="190" styleClass="logout-button" stylesheets="@dashboard.css" text="Logout">

                    <graphic>

                        <FontIcon iconColor="WHITE" iconLiteral="fas-sign-out-alt" iconSize="20" />

                    </graphic>

                </Button>

                <!-- LOGO -->

                <FontIcon iconColor="WHITE" iconLiteral="fas-store" iconSize="75" layoutX="95" layoutY="100" />

                <Text fill="WHITE" layoutX="45" layoutY="170" text="Dashboard">

                    <font>
                        <Font size="30" />
                    </font>

                </Text>

                <!-- MENU -->

                <Button layoutX="20" layoutY="240" onAction="#abrirUsuarios" prefWidth="230" styleClass="menu-button" text="Usuários">

                    <graphic>
                        <FontIcon iconColor="WHITE" iconLiteral="fas-users" iconSize="20" />
                    </graphic>

                </Button>

                <Button layoutX="20" layoutY="300" onAction="#abrirProdutos" prefWidth="230" styleClass="menu-button" stylesheets="@dashboard.css" text="Produtos">

                    <graphic>
                        <FontIcon iconColor="WHITE" iconLiteral="fas-box-open" iconSize="20" />
                    </graphic>

                </Button>

                <Button layoutX="20" layoutY="360" onAction="#abrirFornecedores" prefWidth="230" styleClass="menu-button" stylesheets="@dashboard.css" text="Fornecedores">

                    <graphic>
                        <FontIcon iconColor="WHITE" iconLiteral="fas-truck" iconSize="20" />
                    </graphic>

                </Button>

                <Button layoutX="20" layoutY="420" onAction="#abrirVendas" prefWidth="230" styleClass="menu-button" stylesheets="@dashboard.css" text="Vendas">

                    <graphic>
                        <FontIcon iconColor="WHITE" iconLiteral="fas-shopping-cart" iconSize="20" />
                    </graphic>

                </Button>

                <Button layoutX="20" layoutY="480" onAction="#abrirFinanceiro" prefWidth="230" styleClass="menu-button" stylesheets="@dashboard.css" text="Financeiro">

                    <graphic>
                        <FontIcon iconColor="WHITE" iconLiteral="fas-dollar-sign" iconSize="20" />
                    </graphic>

                </Button>

                <Button layoutX="20" layoutY="540" onAction="#abrirRelatorios" prefWidth="230" styleClass="menu-button" stylesheets="@dashboard.css" text="Relatórios">

                    <graphic>
                        <FontIcon iconColor="WHITE" iconLiteral="fas-chart-line" iconSize="20" />
                    </graphic>

                </Button>

            </children>

        </AnchorPane>

    </left>

      <!-- ===================================================== -->
    <!-- ÁREA CENTRAL -->
    <!-- ===================================================== -->

    <center>

        <AnchorPane styleClass="dashboard-background" stylesheets="@dashboard.css">

            <children>

                <!-- ===================================================== -->
                <!-- CARD USUÁRIOS -->
                <!-- ===================================================== -->

                <AnchorPane layoutX="40" layoutY="40" onMouseClicked="#abrirUsuarios" prefHeight="300" prefWidth="360" styleClass="card" stylesheets="@dashboard.css">

                    <children>

                        <FontIcon iconColor="#0598ff" iconLiteral="fas-users" iconSize="90" layoutX="135" layoutY="110" />

                        <Text layoutX="95" layoutY="190" styleClass="card-title" text="Usuários" />

                        <Text layoutX="50" layoutY="230" styleClass="card-subtitle" text="Gerencie usuários do sistema" />

                    </children>

                </AnchorPane>

                <!-- ===================================================== -->
                <!-- CARD PRODUTOS -->
                <!-- ===================================================== -->

                <AnchorPane layoutX="430" layoutY="40" onMouseClicked="#abrirProdutos" prefHeight="300" prefWidth="360" styleClass="card" stylesheets="@dashboard.css">

                    <children>

                        <FontIcon iconColor="#0598ff" iconLiteral="fas-box-open" iconSize="90" layoutX="135" layoutY="110" />

                        <Text layoutX="95" layoutY="190" styleClass="card-title" text="Produtos" />

                        <Text layoutX="55" layoutY="230" styleClass="card-subtitle" text="Controle de estoque e catálogo" />

                    </children>

                </AnchorPane>

                <!-- ===================================================== -->
                <!-- CARD FORNECEDORES -->
                <!-- ===================================================== -->

                <AnchorPane layoutX="820" layoutY="40" onMouseClicked="#abrirFornecedores" prefHeight="300" prefWidth="360" styleClass="card" stylesheets="@dashboard.css">

                    <children>

                        <FontIcon iconColor="#0598ff" iconLiteral="fas-truck" iconSize="90" layoutX="135" layoutY="110" />

                        <Text layoutX="55" layoutY="190" styleClass="card-title" text="Fornecedores" />

                        <Text layoutX="55" layoutY="230" styleClass="card-subtitle" text="Controle de fornecedores" />

                    </children>

                </AnchorPane>

                <!-- ===================================================== -->
                <!-- CARD VENDAS -->
                <!-- ===================================================== -->

                <AnchorPane layoutX="40" layoutY="390" onMouseClicked="#abrirVendas" prefHeight="300" prefWidth="360" styleClass="card" stylesheets="@dashboard.css">

                    <children>

                        <FontIcon iconColor="#0598ff" iconLiteral="fas-shopping-cart" iconSize="90" layoutX="125" layoutY="110" />

                        <Text layoutX="115" layoutY="190" styleClass="card-title" text="Vendas" />

                        <Text layoutX="60" layoutY="230" styleClass="card-subtitle" text="Gerenciamento de vendas" />

                    </children>

                </AnchorPane>

                <!-- ===================================================== -->
                <!-- CARD FINANCEIRO -->
                <!-- ===================================================== -->

                <AnchorPane layoutX="418.0" layoutY="407.0" onMouseClicked="#abrirFinanceiro" prefHeight="300" prefWidth="360" styleClass="card" stylesheets="@dashboard.css">

                    <children>

                        <FontIcon iconColor="#0598ff" iconLiteral="fas-dollar-sign" iconSize="90" layoutX="145" layoutY="110" />

                        <Text layoutX="85" layoutY="190" styleClass="card-title" text="Financeiro" />

                        <Text layoutX="55" layoutY="230" styleClass="card-subtitle" text="Controle financeiro geral" />

                    </children>

                </AnchorPane>

                <!-- ===================================================== -->
                <!-- CARD RELATÓRIOS -->
                <!-- ===================================================== -->

                <AnchorPane layoutX="820" layoutY="390" onMouseClicked="#abrirRelatorios" prefHeight="300" prefWidth="360" styleClass="card" stylesheets="@dashboard.css">

                    <children>

                        <FontIcon iconColor="#0598ff" iconLiteral="fas-chart-line" iconSize="90" layoutX="135" layoutY="110" />

                        <Text layoutX="70" layoutY="190" styleClass="card-title" text="Relatórios" />

                        <Text layoutX="50" layoutY="230" styleClass="card-subtitle" text="Estatísticas e relatórios" />

                    </children>

                </AnchorPane>

            </children>

        </AnchorPane>

    </center>

</BorderPane>
