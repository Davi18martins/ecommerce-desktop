<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="500.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.edu.tds.ecommerce.TelaGerenciamentoProdutosController">
   <top>
      <HBox alignment="CENTER" prefHeight="48.0" prefWidth="700.0" style="-fx-background-color: #277CE0;" BorderPane.alignment="CENTER">
         <children>
            <Label alignment="CENTER" prefHeight="84.0" prefWidth="700.0" style="-fx-background-color: black; -fx-font-size: 20; -fx-font-weight: 800;" text="Gerenciamento de Carros" textFill="WHITE" />
         </children>
      </HBox>
   </top>
   <bottom>
      <HBox alignment="CENTER" prefHeight="56.0" prefWidth="700.0" spacing="20.0" style="-fx-background-color: black;" BorderPane.alignment="CENTER">
         <children>
            <Button mnemonicParsing="false" onAction="#abrirTelaCadastroProduto" style="-fx-background-color: #277CE0;" text="+ Novo" textFill="WHITE" />
            <Button mnemonicParsing="false" onAction="#editarProduto" style="-fx-background-color: #f26900;" text="| Editar" textFill="WHITE" />
            <Button mnemonicParsing="false" onAction="#excluirProduto" style="-fx-background-color: red;" text="x Excluir" textFill="WHITE" />
         </children>
         <BorderPane.margin>
            <Insets />
         </BorderPane.margin>
      </HBox>
   </bottom>
   <center>
      <TableView fx:id="tabelaProdutos" prefHeight="396.0" prefWidth="768.0" style="-fx-background-color: #277CE0;" BorderPane.alignment="CENTER">
        <columns>
            <TableColumn fx:id="colNomeCarro" prefWidth="182.0" text="Nome Carro" />
          <TableColumn fx:id="colModeloCarro" minWidth="7.0" prefWidth="158.0" text="Modelo de Carro" />
            <TableColumn fx:id="colPreco" prefWidth="110.0" text="Preço" />
            <TableColumn fx:id="colQuantidade" prefWidth="113.0" text="Quantidade" />
            <TableColumn fx:id="colAtivo" prefWidth="136.0" text="Ativo" />
        </columns>
      </TableView>
   </center>
</BorderPane>
