<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="500.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.edu.tds.telalogin.TelaGerenciamentoUsuariosController">
   <top>
      <HBox alignment="CENTER" prefHeight="48.0" prefWidth="700.0" style="-fx-background-color: #277CE0;" BorderPane.alignment="CENTER">
         <children>
            <Label alignment="CENTER" prefHeight="47.0" prefWidth="700.0" style="-fx-background-color: #277CE0; -fx-font-size: 20; -fx-font-weight: 800;" text="Gerenciamento de Usuários" textFill="WHITE" />
         </children>
      </HBox>
   </top>
   <bottom>
      <HBox alignment="CENTER" prefHeight="56.0" prefWidth="700.0" spacing="20.0" BorderPane.alignment="CENTER">
         <children>
            <Button mnemonicParsing="false" onAction="#abrirTelaCadastroUsuario" style="-fx-background-color: #277CE0;" text="+ Novo" textFill="WHITE" />
            <Button mnemonicParsing="false" style="-fx-background-color: #f26900;" text="| Editar" textFill="WHITE" />
            <Button mnemonicParsing="false" onAction="#excluirUsuario" style="-fx-background-color: red;" text="x Excluir" textFill="WHITE" />
         </children>
         <BorderPane.margin>
