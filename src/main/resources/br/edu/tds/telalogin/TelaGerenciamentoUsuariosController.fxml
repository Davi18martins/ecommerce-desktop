         </BorderPane.margin>
      </HBox>
   </bottom>
   <center>
      <TableView fx:id="tabelaUsuarios" prefHeight="437.0" prefWidth="700.0" BorderPane.alignment="CENTER">
        <columns>
            <TableColumn fx:id="colNomeCompleto" prefWidth="187.0" text="Nome Completo" />
          <TableColumn fx:id="colUsuario" minWidth="7.0" prefWidth="173.0" text="Usuário" />
            <TableColumn fx:id="colEmail" prefWidth="150.0" text="Email" />
            <TableColumn fx:id="colCPF" prefWidth="189.0" text="CPF" />
        </columns>
      </TableView>
   </center>
</BorderPane>
